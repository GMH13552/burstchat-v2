# burstchat 分析工具配置
# 复制为 .env 并填写

# 工作目录（分析结果输出位置）
WORKSPACE=C:\Users\GMH13\.openclaw\workspace

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-your-key-here…7397

# 微信数据库目录（用于自动提取聊天记录）
# WeChatMsg 导出后的 decrypted 目录路径
# WECHAT_DB_DIR=C:\Users\GMH13\Documents\WeChat Files\wxid_xxx\Msg

# 聊天记录中"我"的显示名称
WECHAT_SELF_NAME=我
